BIFROST_BACKEND_PORT=8080
BIFROST_FRONTEND_PORT=3000
BIFROST_BACKEND_IMAGE=ghcr.io/dipeshsingh253/bifrost-backend:latest
BIFROST_FRONTEND_IMAGE=ghcr.io/dipeshsingh253/bifrost-frontend:latest

BIFROST_LISTEN_ADDR=:8080
BIFROST_JWT_SECRET=replace-this-in-production
BIFROST_DATABASE_URL=postgres://username:password@postgres-host:5432/bifrost?sslmode=disable
BIFROST_AGENT_BACKEND_URL=https://bifrost.example.com
BIFROST_AGENT_DOCKER_IMAGE=ghcr.io/dipeshsingh253/bifrost-agent:latest
BIFROST_AGENT_BINARY_PATH=
BIFROST_AGENT_SOURCE_DIR=../agent
BIFROST_SEED_DEMO_DATA=false

BIFROST_API_BASE_URL=http://bifrost-backend:8080
